# ============================================================================ #
# NoneBot 运行环境配置（模板 — 可安全提交到 git）
# 复制此文件为 .env 并填入真实的 API Key
# ============================================================================ #

# --- Driver（必须）---
DRIVER=~fastapi+~httpx

# --- HTTP 服务监听 ---
HOST=127.0.0.1
PORT=8080

# --- 超级用户（QQ号，可以多个）---
SUPERUSERS=[""]

# --- 命令前缀 ---
COMMAND_START=["/"]
COMMAND_SEP=["."]

# --- 日志级别 ---
LOG_LEVEL=INFO

# --- API Key（必填，填入你自己的 key）---
YUKI_API_KEY=your-reply-model-api-key-here
YUKI_DECISION_API_KEY=
